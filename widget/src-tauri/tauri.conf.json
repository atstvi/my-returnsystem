{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Return Widget",
  "version": "0.1.0",
  "identifier": "com.return.widget",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Return Widget",
        "url": "http://localhost:14317",
        "width": 320,
        "height": 440,
        "minWidth": 240,
        "minHeight": 200,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "alwaysOnTop": false,
        "shadow": false,
        "skipTaskbar": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}

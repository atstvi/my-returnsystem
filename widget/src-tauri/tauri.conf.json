{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Return Widget",
  "version": "0.5.0",
  "identifier": "com.return.widget",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "habits",
        "title": "Return 해빗",
        "url": "http://localhost:14317/",
        "width": 300,
        "height": 420,
        "minWidth": 220,
        "minHeight": 200,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "alwaysOnTop": false,
        "shadow": false,
        "skipTaskbar": false,
        "center": true
      },
      {
        "label": "timeline",
        "title": "Return 타임블록",
        "url": "http://localhost:14317/?view=timeline",
        "width": 280,
        "height": 540,
        "minWidth": 220,
        "minHeight": 300,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "alwaysOnTop": false,
        "shadow": false,
        "skipTaskbar": false,
        "center": true
      },
      {
        "label": "timer",
        "title": "Return 타이머",
        "url": "http://localhost:14317/?view=timer",
        "width": 240,
        "height": 360,
        "minWidth": 200,
        "minHeight": 280,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "alwaysOnTop": false,
        "shadow": false,
        "skipTaskbar": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}

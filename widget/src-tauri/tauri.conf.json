{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Return Widget",
  "version": "0.9.0",
  "identifier": "com.return.widget",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "habits",
        "title": "Return 해빗",
        "url": "http://localhost:14317/",
        "width": 300,
        "height": 420,
        "minWidth": 220,
        "minHeight": 200,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "alwaysOnTop": false,
        "shadow": false,
        "skipTaskbar": false,
        "center": true
      },
      {
        "label": "timeline",
        "title": "Return 타임블록",
        "url": "http://localhost:14317/?view=timeline",
        "width": 280,
        "height": 540,
        "minWidth": 220,
        "minHeight": 300,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "alwaysOnTop": false,
        "shadow": false,
        "skipTaskbar": false,
        "center": true
      },
      {
        "label": "workstation",
        "title": "Return 작업대",
        "url": "http://localhost:14317/?view=workstation",
        "width": 300,
        "height": 540,
        "minWidth": 240,
        "minHeight": 360,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "alwaysOnTop": false,
        "shadow": false,
        "skipTaskbar": false,
        "center": true
      },
      {
        "label": "calendar",
        "title": "Return 달력",
        "url": "http://localhost:14317/?view=calendar",
        "width": 300,
        "height": 380,
        "minWidth": 240,
        "minHeight": 300,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "alwaysOnTop": false,
        "shadow": false,
        "skipTaskbar": false,
        "center": true
      },
      {
        "label": "quickinput",
        "title": "Return 빠른 입력",
        "url": "http://localhost:14317/?view=quickinput",
        "width": 300,
        "height": 280,
        "minWidth": 240,
        "minHeight": 200,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "alwaysOnTop": false,
        "shadow": false,
        "skipTaskbar": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/atstvi/my-returnsystem/releases/latest/download/latest.json"
      ],
      "pubkey": "REPLACE_WITH_TAURI_PUBLIC_KEY"
    }
  }
}
